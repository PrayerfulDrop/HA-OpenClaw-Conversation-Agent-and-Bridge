# Port for the HA bridge HTTP server
PORT=8080

# URL for the OpenClaw gateway / brain endpoint (to be wired up later)
# Example: http://openclaw-gateway:8080
OPENCLAW_BASE_URL=http://localhost:8080

# Optional Home Assistant settings if we decide to call HA directly
# (service calls, entity lookups, etc.)
HOME_ASSISTANT_BASE_URL=http://homeassistant:8123
HOME_ASSISTANT_TOKEN=changeme

# Safety: by default, the bridge WILL NOT execute HA actions.
# Set EXECUTE_HA_ACTIONS=true (or 1) once you're happy with what the
# model is asking to do in the `actions` array.
EXECUTE_HA_ACTIONS=false

# Optional OpenAI-compatible LLM settings for the brain
# Example for a local server on llm-home:
#   LLM_BASE_URL=http://llm-home:8000/v1
#   LLM_MODEL=gemma-2-27b
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
